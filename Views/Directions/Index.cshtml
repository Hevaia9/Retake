@model IEnumerable<RetakeSystem.Models.Direction>
@{
    ViewData["Title"] = "Направления на пересдачу";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📑 Направления на пересдачу</h2>
        <div>
            <a href="/Import" class="btn btn-secondary">← К импорту</a>
            @if (Model.Any())
            {
                <form asp-action="DeleteAll" method="post" class="d-inline" onsubmit="return confirm('Вы уверены, что хотите удалить ВСЕ направления?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">🗑 Удалить все</button>
                </form>
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <!-- Фильтр направлений -->
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0">🔍 Фильтр направлений</h5>
        </div>
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-3">
                    <label for="studentFilter" class="form-label">Студент</label>
                    <input type="text" class="form-control" id="studentFilter" name="studentFilter"
                           value="@ViewBag.StudentFilter" placeholder="ФИО студента..." />
                </div>
                <div class="col-md-2">
                    <label for="groupFilter" class="form-label">Группа</label>
                    <input type="text" class="form-control" id="groupFilter" name="groupFilter"
                           value="@ViewBag.GroupFilter" placeholder="ИСП-31..." />
                </div>
                <div class="col-md-3">
                    <label for="disciplineFilter" class="form-label">Дисциплина</label>
                    <input type="text" class="form-control" id="disciplineFilter" name="disciplineFilter"
                           value="@ViewBag.DisciplineFilter" placeholder="Название дисциплины..." />
                </div>
                <div class="col-md-2">
                    <label for="statusFilter" class="form-label">Статус</label>
                    <select class="form-select" id="statusFilter" name="statusFilter">
                        <option value="">Все статусы</option>
                        @if (ViewBag.StatusFilter == "active")
                        {
                            <option value="active" selected>Активно</option>
                        }
                        else
                        {
                            <option value="active">Активно</option>
                        }

                        @if (ViewBag.StatusFilter == "closed")
                        {
                            <option value="closed" selected>Закрыто</option>
                        }
                        else
                        {
                            <option value="closed">Закрыто</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">Применить</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Сбросить</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model.Any())
            {
                <table class="table table-striped table-hover">
                    <thead class="thead-dark">
                        <tr>
                            <th>№ направления</th>
                            <th>Студент</th>
                            <th>Группа</th>
                            <th>Дисциплина</th>
                            <th>Дата выдачи</th>
                            <th>Срок</th>
                            <th>Статус</th>
                            <th>Оценка</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Number</td>
                                <td>@item.Student?.FullName</td>
                                <td>@item.Student?.Group</td>
                                <td>@item.Discipline?.Title</td>
                                <td>@item.DateStart.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (item.Status == "active")
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            <span id="dateDisplay_@item.Id" class="badge bg-light text-dark">
                                                @item.DateEnd.ToString("dd.MM.yyyy")
                                            </span>
                                            <input type="date" id="datePicker_@item.Id"
                                                   value="@item.DateEnd.ToString("yyyy-MM-dd")"
                                                   class="form-control form-control-sm"
                                                   style="width: 140px; display: none;" />
                                            <button type="button" class="btn btn-sm btn-outline-primary"
                                                    onclick="toggleDatePicker(@item.Id)" title="Изменить дату">
                                                📅
                                            </button>
                                            <button type="button" class="btn btn-sm btn-success"
                                                    onclick="saveDate(@item.Id)" title="Сохранить">
                                                ✓
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">@item.DateEnd.ToString("dd.MM.yyyy")</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Status == "active")
                                    {
                                        <span class="badge bg-warning text-dark">Активно</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Закрыто</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Estimate.HasValue)
                                    {
                                        <span class="badge bg-primary">@item.Estimate.Value</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-info" onclick="printDirection(@item.Id)">
                                        🖨 Печать
                                    </button>
                                    @if (item.Status == "active")
                                    {
                                        <form asp-action="SetGrade" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <select name="estimate" class="form-control form-control-sm d-inline" style="width: 70px;">
                                                <option value="">Оценка</option>
                                                <option value="2">2</option>
                                                <option value="3">3</option>
                                                <option value="4">4</option>
                                                <option value="5">5</option>
                                            </select>
                                            <button type="submit" class="btn btn-sm btn-success">✓</button>
                                        </form>
                                    }
                                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Удалить это направление?');">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">🗑</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info text-center">
                    Направления пока не созданы. Загрузите Excel файл на странице импорта.
                </div>
            }
        </div>
    </div>
</div>

<!-- Скрытый iframe для печати без перехода на новую страницу -->
<iframe id="printFrame" name="printFrame" style="display:none; width:0; height:0; border:0;"></iframe>

@section Scripts {
    <script>
        // Показать/скрыть date picker
        function toggleDatePicker(id) {
            var picker = document.getElementById('datePicker_' + id);
            var display = document.getElementById('dateDisplay_' + id);

            if (picker.style.display === 'none') {
                picker.style.display = 'inline-block';
                display.style.display = 'none';
                picker.focus();
            } else {
                picker.style.display = 'none';
                display.style.display = 'inline';
            }
        }

        // Сохранить дату через AJAX
        function saveDate(id) {
            var datePicker = document.getElementById('datePicker_' + id);
            var dateDisplay = document.getElementById('dateDisplay_' + id);
            var newDate = datePicker.value;

            if (!newDate) {
                alert('Выберите дату!');
                return;
            }

            var tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            if (!tokenInput) {
                alert('Ошибка: не найден токен безопасности');
                return;
            }
            var token = tokenInput.value;

            fetch('/Directions/UpdateDateEnd', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'id=' + id + '&dateEnd=' + newDate
            })
            .then(response => {
                if (response.ok) {
                    var dateParts = newDate.split('-');
                    var formattedDate = dateParts[2] + '.' + dateParts[1] + '.' + dateParts[0];
                    dateDisplay.textContent = formattedDate;
                    dateDisplay.style.display = 'inline';
                    datePicker.style.display = 'none';
                    alert('✅ Срок действия обновлен!');
                } else {
                    alert('❌ Ошибка при сохранении даты');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('❌ Произошла ошибка при сохранении');
            });
        }

        //  ПЕЧАТЬ НАПРАВЛЕНИЯ ПРЯМО ИЗ ТАБЛИЦЫ (без перехода на новую страницу)
        function printDirection(id) {
            var frame = document.getElementById('printFrame');
            frame.src = '/Directions/Print/' + id;

            frame.onload = function() {
                // Ждём 500мс пока страница полностью загрузится
                setTimeout(function() {
                    try {
                        frame.contentWindow.focus();
                        frame.contentWindow.print();
                    } catch (e) {
                        alert('Ошибка печати. Откройте направление вручную.');
                    }
                }, 500);
            };
        }
    </script>
}