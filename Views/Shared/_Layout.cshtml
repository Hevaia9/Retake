<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Retake System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">Retake System</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Import" asp-action="Index">Импорт ведомостей</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="RetakeSheet" asp-action="Index">Перезачет</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Directions" asp-action="Index">Ведомости</a>
                        </li>
                    </ul>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="d-flex align-items-center">
                            <span class="text-light me-3">admin</span>
                            <a asp-controller="Account" asp-action="Logout"
                               class="btn btn-outline-danger btn-sm">
                                Выход
                            </a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        @RenderBody()
    </div>

    @RenderSection("Scripts", required: false)

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>